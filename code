        //        // UP ẢNH THỰC TẾ (Base64)
        function previewUploadImage(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            if (file.size > 5 * 1024 * 1024) {
                showToast("Kích thước ảnh tối đa là 5MB!", "error");
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                uploadedImageBase64 = e.target.result;
                document.getElementById('post-img-preview').src = uploadedImageBase64;
                document.getElementById('post-img-name').textContent = file.name;
                document.getElementById('post-img-preview-container').classList.remove('hidden');
                document.getElementById('upload-status').textContent = "Đã nhận";
            };
            reader.readAsDataURL(file);
        }

        function removeUploadImage() {
            uploadedImageBase64 = null;
            document.getElementById('post-img-file').value = '';
            document.getElementById('post-img-preview-container').classList.add('hidden');
            document.getElementById('upload-status').textContent = "Tải ảnh...";
        }

