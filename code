        //        // HỘI THOẠI TRONG PHÒNG CHAT
        function initiateChat() {
            if (!selectedProduct) return;

            document.getElementById('chat-partner-name').textContent = selectedProduct.posterName;
            document.getElementById('chat-header-avatar').textContent = selectedProduct.posterAvatar;
            document.getElementById('chat-item-img').src = selectedProduct.image;
            document.getElementById('chat-item-title').textContent = selectedProduct.title;

            if (!chatMessagesHistory[selectedProduct.id]) {
                chatMessagesHistory[selectedProduct.id] = [
                    { type: 'partner', text: `Chào bạn! Mình muốn thanh lý món [${selectedProduct.title}] này nhé. Bạn có muốn qua xem thử không?` }
                ];
            }

            renderChatMessages();
            switchView('chat');
        }

        function renderChatMessages() {
            const container = document.getElementById('chat-messages-container');
            container.innerHTML = '';

            const history = chatMessagesHistory[selectedProduct.id];
            history.forEach(msg => {
                const row = document.createElement('div');
                if (msg.type === 'partner') {
                    row.className = "flex gap-3 max-w-[85%]";
                    row.innerHTML = `
                        <div class="w-8 h-8 rounded-full bg-sky-200 flex items-center justify-center font-bold text-xs shrink-0">${selectedProduct.posterAvatar}</div>
                        <div class="bg-white p-3 rounded-2xl rounded-tl-none border border-slate-100 shadow-sm text-sm text-slate-700 leading-relaxed">
                            ${msg.text}
                        </div>
                    `;
                } else if (msg.type === 'self') {
                    row.className = "flex gap-3 max-w-[85%] ml-auto justify-end";
                    row.innerHTML = `
                        <div class="bg-sky-500 p-3 rounded-2xl rounded-tr-none shadow-sm text-sm text-white leading-relaxed">
                            ${msg.text}
                        </div>
                    `;
                } else if (msg.type === 'system') {
                    row.className = "flex justify-center";
                    row.innerHTML = `
                        <div class="bg-sky-50/50 border border-sky-100 px-4 py-2 rounded-2xl text-[11px] text-sky-700 font-bold flex items-center gap-1.5 shadow-sm">
                            ${msg.text}
                        </div>
                    `;
                }
                container.appendChild(row);
            });

            container.scrollTop = container.scrollHeight;
        }

        function handleSendChatMessage(e) {
            e.preventDefault();
            const input = document.getElementById('chat-input');
            const val = input.value.trim();
            if(!val) return;

            sendChatMessage(val);
            input.value = '';
        }

        function sendChatMessage(text, type = 'self') {
            chatMessagesHistory[selectedProduct.id].push({ type: type, text: text });
            renderChatMessages();

            if (type === 'self') {
                setTimeout(() => {
                    chatMessagesHistory[selectedProduct.id].push({ 
                        type: 'partner', 
                        text: "Dạ vâng ạ! Bạn đề xuất địa điểm xem hàng tiện lợi cho bạn nhé!" 
                    });
                    renderChatMessages();
                }, 1000);
            }
        }

