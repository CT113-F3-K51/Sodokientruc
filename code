        //        // BỘ ĐIỀU HƯỚNG BỘ LỌC DANH MỤC & VỊ TRÍ (UC03)
        function selectCategory(cat) {
            activeCategory = cat;
            document.querySelectorAll('#category-filters button').forEach(btn => {
                btn.className = "w-full flex items-center gap-3 p-2 hover:bg-sky-50 rounded-xl transition-all text-left text-slate-600";
                const icon = btn.querySelector('div');
                if(icon) icon.className = "w-6 text-center text-sky-500";
            });

            const activeBtn = document.getElementById(`cat-${cat}`);
            if (activeBtn) {
                activeBtn.className = "w-full flex items-center gap-3 p-2 bg-sky-500 text-white rounded-xl font-bold transition-all text-left";
                const icon = activeBtn.querySelector('div');
                if(icon) icon.className = "w-6 text-center text-white";
            }
            applyFilters();
        }

        document.getElementById('location-filters').addEventListener('change', function(e) {
            if(e.target.name === 'loc') {
                activeLocation = e.target.value;
                applyFilters();
            }
        });

        // ÁP DỤNG BỘ LỌC TÌM KIẾM TỔNG HỢP (UC03 - Bảo mật chặn ký tự lạ NL-2)
        function applyFilters() {
            const rawSearchVal = document.getElementById('search-input').value;
            
            // Xử lý bảo mật: Chặn các câu lệnh Sql Injection/Tag Script lạ (UC03 NL-2)
            const containsSpecial = /[\<\>\'\"\\\{\}\[\]\^\;\%\=\*\+]/g.test(rawSearchVal);
            if (containsSpecial) {
                showModal("Cảnh báo bảo mật", "Từ khóa tìm kiếm không hợp lệ. Vui lòng không sử dụng các ký tự đặc biệt.", "error");
                document.getElementById('search-input').value = "";
                return;
            }

            const searchVal = rawSearchVal.trim().toLowerCase();
            const filtered = mockProducts.filter(p => {
                const matchSearch = p.title.toLowerCase().includes(searchVal) || p.desc.toLowerCase().includes(searchVal);
                const matchCat = activeCategory === 'all' || p.category === activeCategory;
                const matchLoc = activeLocation === 'all' || p.location === activeLocation;
                return matchSearch && matchCat && matchLoc;
            });

            renderProducts(filtered);
        }

        function resetFilters() {
            document.getElementById('search-input').value = '';
            document.querySelector('input[name="loc"][value="all"]').checked = true;
            activeLocation = "all";
            selectCategory('all');
        }

        //        // GỢI Ý TỪ KHÓA AUTOCOMPLETE (UC03)
        function showSuggestions(show) {
            const box = document.getElementById('search-suggestions');
            if(show) {
                const items = document.getElementById('suggestion-items');
                items.innerHTML = '';
                
                searchKeywords.forEach(kw => {
                    const row = document.createElement('div');
                    row.className = "px-4 py-2.5 hover:bg-sky-50 cursor-pointer text-sm text-slate-700 font-semibold flex items-center gap-2";
                    row.innerHTML = `<i class="fa-solid fa-magnifying-glass text-xs text-sky-400"></i> ${kw}`;
                    row.onmousedown = () => {
                        document.getElementById('search-input').value = kw;
                        applyFilters();
                    };
                    items.appendChild(row);
                });
                box.classList.remove('hidden');
            } else {
                box.classList.add('hidden');
            }
        }

        function handleSearchInput() {
