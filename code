                        </div>
                        <div class="text-[10px] text-slate-400"><b>Mã:</b> ${tx.txId} | <b>Thời gian:</b> ${tx.time}</div>
                        <div class="text-[10px] text-slate-500"><i class="fa-solid fa-map-location-dot"></i> <b>Nơi hẹn:</b> ${tx.address}</div>
                    </div>
                    <div class="sm:text-right shrink-0">
                        <div class="font-extrabold text-sky-500 text-sm">${formatPrice(tx.amount)}</div>
                        <div class="text-[9px] text-slate-400 uppercase font-black">Ví: ${tx.method}</div>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        // BẢNG QUẢN TRỊ ADMIN (ADMIN DASHBOARD)
        function updateAdminDashboard() {
            const activeList = mockProducts.filter(p => p.status === 'approved');
            const totalProductsCount = mockProducts.length;
            const spamCount = mockProducts.filter(p => p.status === 'spam').length;
            
            document.getElementById('stat-total').textContent = totalProductsCount;
            document.getElementById('stat-pending').textContent = activeList.length;
            document.getElementById('stat-banned').textContent = spamCount;

            const tbody = document.getElementById('admin-pending-table');
            tbody.innerHTML = '';

            mockProducts.forEach(p => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-slate-50 transition-colors";
                
                let actionBtn = "";
                if (p.status === 'approved') {
                    actionBtn = `<button onclick="adminAction(${p.id}, 'spam')" class="bg-red-500 hover:bg-red-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-all"><i class="fa-solid fa-ban"></i> Chặn</button>`;
                } else if (p.status === 'spam') {
                    actionBtn = `<button onclick="adminAction(${p.id}, 'approved')" class="bg-emerald-500 hover:bg-emerald-600 text-white px-3 py-1.5 rounded-lg text-xs font-bold transition-all"><i class="fa-solid fa-arrow-rotate-left"></i> Khôi phục</button>`;
                } else {
                    actionBtn = `<span class="text-xs text-slate-400 font-bold">Đã bán</span>`;
                }

                tr.innerHTML = `
                    <td class="p-4"><img src="${p.image}" class="w-12 h-12 rounded-lg object-cover"></td>
                    <td class="p-4 font-bold text-slate-800">${p.title}</td>
                    <td class="p-4 text-xs"><span class="bg-sky-100 text-sky-700 px-2.5 py-1 rounded-full font-bold">${p.category}</span></td>
                    <td class="p-4 font-extrabold text-sky-600">${formatPrice(p.price)}</td>
                    <td class="p-4 font-bold text-slate-600 text-center">${p.stock}</td>
                    <td class="p-4 text-center">
                        <div class="flex gap-2 justify-center">
                            ${actionBtn}
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function adminAction(id, action) {
            const product = mockProducts.find(p => p.id === id);
            if(product) {
                product.status = action;
                showToast(action === 'approved' ? "Đã khôi phục bài đăng sinh viên!" : "Đã loại bỏ bài đăng vi phạm!");
                updateAdminDashboard();
                applyFilters();
            }
        }

        // KHỞI ĐỘNG HỆ THỐNG
        window.onload = function() {
            // Kiểm tra "Ghi nhớ đăng nhập" (UC01)
            const savedUser = localStorage.getItem('rememberedUser');
            if (savedUser) {
                currentUser = JSON.parse(savedUser);
                document.getElementById('user-display-name').textContent = currentUser.name;
                showToast(`Chào mừng quay trở lại, ${currentUser.name}! (Nhớ phiên)`);
                switchView('home');
            } else {
                switchView('auth');
            }
            applyFilters();
        };
    </script>
</body>
</html>
