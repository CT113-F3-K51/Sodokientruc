        // ĐĂNG BÁN TRỰC TIẾP (Approved luôn, bỏ qua kiểm duyệt Admin)
        function handlePostSubmit(e) {
            e.preventDefault();
            const title = document.getElementById('post-title').value.trim();
            const desc = document.getElementById('post-desc').value.trim();
            const price = parseFloat(document.getElementById('post-price').value);
            const cat = document.getElementById('post-cat').value;
            const loc = document.getElementById('post-loc').value;
            const stockVal = parseInt(document.getElementById('post-stock').value) || 1;

            let img = uploadedImageBase64;
            if (!img) {
                if (cat === 'HocTap') img = "https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=400&h=300";
                else if (cat === 'CongNghe') img = "https://images.unsplash.com/photo-1588872657578-7efd1f1555ed?auto=format&fit=crop&q=80&w=400&h=300";
                else if (cat === 'GiaDung') img = "https://images.unsplash.com/photo-1618621213009-8806c9a6d917?auto=format&fit=crop&q=80&w=400&h=300";
                else img = "https://images.unsplash.com/photo-1593642632823-8f785ba67e45?auto=format&fit=crop&q=80&w=400&h=300";
            }

            const textToCheck = `${title} ${desc}`.toLowerCase();
            let containsBanned = false;
            let foundWord = '';

            for (let word of bannedKeywords) {
                if (textToCheck.includes(word)) {
                    containsBanned = true;
                    foundWord = word;
                    break;
                }
            }

            if (containsBanned) {
                showModal("Không được đăng tin!", `Tin đăng của bạn chứa từ khóa nằm trong danh mục cấm: <b>"${foundWord}"</b>.<br>Quy định nhà trường nghiêm cấm mua bán vũ khí, chất cấm hoặc lừa đảo cọc tiền trên Student Market.`, "error");
                return;
            }

            const newPost = {
                id: mockProducts.length + 1,
                title: title,
                price: price,
                category: cat,
                location: loc,
                timeAgo: "Vừa xong",
                posterName: currentUser ? currentUser.name : "Sinh viên",
                posterAvatar: (currentUser && currentUser.name ? currentUser.name[0] : "S").toUpperCase(),
                status: "approved", 
                image: img,
                desc: desc,
                stock: stockVal
            };

            mockProducts.unshift(newPost);
            
            document.getElementById('form-post').reset();
            removeUploadImage();

            showModal("Đăng Tin Thành Công!", "Bài viết đã được tự động duyệt và xuất bản trực tiếp lên dòng tin trang chủ!", "success");
            switchView('home');
            applyFilters();
        }

