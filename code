<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Market | Sàn Giao Dịch & Thanh Lý Đồ Cũ Sinh Viên</title>
    <!-- Nhúng Tailwind CSS để xử lý giao diện nhanh, mượt -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Nhúng FontAwesome cho các icon -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
        body { font-family: 'Inter', sans-serif; background-color: #f0f9ff; }
        
        /* Ẩn thanh cuộn mặc định nhưng vẫn cho phép cuộn */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        /* Chuyển động chuyển màn hình mượt mà */
        .view-section { animation: slideUp 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
        
        @keyframes slideUp {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Vòng xoay khi tải trang */
        .loader {
            border: 3px solid #f3f3f3; border-top: 3px solid #0ea5e9;
            border-radius: 50%; width: 28px; height: 28px; animation: spin 0.8s linear infinite;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body class="text-slate-800 h-screen overflow-hidden flex flex-col bg-sky-50/30">

    <!-- TOAST NOTIFICATION (Thay thế alert) -->
    <div id="toast-container" class="fixed top-5 right-5 z-[200] space-y-2 pointer-events-none"></div>

    <!-- -->
    <!-- CUSTOM POPUP MODAL (Để báo thành công/thất bại) -->
    <div id="ui-modal" class="fixed inset-0 bg-slate-900/60 z-[150] hidden flex items-center justify-center backdrop-blur-sm transition-opacity">
        <div class="bg-white rounded-2xl shadow-2xl w-11/12 max-w-md p-6 text-center transform scale-95 transition-all duration-300" id="ui-modal-content">
            <div id="modal-icon" class="w-16 h-16 rounded-full mx-auto flex items-center justify-center mb-4"></div>
            <h3 id="modal-title" class="text-xl font-bold text-slate-800 mb-2"></h3>
            <p id="modal-message" class="text-slate-600 text-sm leading-relaxed mb-6"></p>
            <button onclick="closeModal()" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-semibold py-3 rounded-xl transition-colors shadow-lg shadow-sky-500/20">Xác nhận</button>
        </div>
    </div>

    <!-- MODAL TRẢ GIÁ NHANH -->
    <div id="deal-modal" class="fixed inset-0 bg-slate-900/60 z-[140] hidden flex items-center justify-center backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-xl w-11/12 max-w-xs p-6">
            <h3 class="text-lg font-bold text-slate-800 mb-4"><i class="fa-solid fa-tags text-sky-500 mr-2"></i>Đề xuất giá mặc cả</h3>
            <div class="space-y-3">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 mb-1">Giá hiện tại</label>
                    <div id="deal-current-price" class="text-lg font-bold text-slate-400 line-through">0 đ</div>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-700 mb-1">Giá bạn muốn đề xuất (đ)</label>
                    <input type="number" id="deal-input-price" class="w-full px-3 py-2 border border-slate-200 rounded-xl focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none" placeholder="Nhập số tiền...">
                </div>
                <div class="flex gap-2 pt-2">
                    <button onclick="toggleDealModal(false)" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-xl text-sm">Hủy</button>
                    <button onclick="submitDealOffer()" class="flex-1 bg-sky-500 hover:bg-sky-600 text-white font-medium py-2 rounded-xl text-sm">Gửi đi</button>
                </div>
            </div>
        </div>
    </div>

    <!-- -->
    <!-- MODAL HẸN ĐỊA ĐIỂM GIAO DỊCH -->
    <div id="meetup-modal" class="fixed inset-0 bg-slate-900/60 z-[140] hidden flex items-center justify-center backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-xl w-11/12 max-w-sm p-6">
            <h3 class="text-lg font-bold text-slate-800 mb-4"><i class="fa-solid fa-location-dot text-sky-500 mr-2"></i>Hẹn địa điểm giao dịch</h3>
            <div class="space-y-3">
                <label class="block text-xs font-semibold text-slate-500">Chọn vị trí an toàn đề xuất:</label>
                <div class="grid grid-cols-1 gap-2">
                    <button onclick="selectMeetupLocation('Cổng 3 ĐH Cần Thơ (Canteen)')" class="text-left p-3 border border-slate-200 rounded-xl hover:border-sky-500 hover:bg-sky-50 text-sm text-slate-700 transition-colors">
                        <i class="fa-solid fa-graduation-cap text-sky-500 mr-2"></i>Cổng 3 ĐH Cần Thơ (Canteen)
                    </button>
                    <button onclick="selectMeetupLocation('Trước sảnh KTX Khu B')" class="text-left p-3 border border-slate-200 rounded-xl hover:border-sky-500 hover:bg-sky-50 text-sm text-slate-700 transition-colors">
                        <i class="fa-solid fa-hotel text-sky-500 mr-2"></i>Trước sảnh KTX Khu B
                    </button>
                    <button onclick="selectMeetupLocation('Quán Cafe đầu hẻm 51 NVC')" class="text-left p-3 border border-slate-200 rounded-xl hover:border-sky-500 hover:bg-sky-50 text-sm text-slate-700 transition-colors">
                        <i class="fa-solid fa-mug-hot text-sky-500 mr-2"></i>Quán Cafe đầu hẻm 51 NVC
                    </button>
                    <button onclick="selectMeetupLocation('Phòng tự học Khoa CNTT-TT')" class="text-left p-3 border border-slate-200 rounded-xl hover:border-sky-500 hover:bg-sky-50 text-sm text-slate-700 transition-colors">
                        <i class="fa-solid fa-laptop text-sky-500 mr-2"></i>Phòng tự học Khoa CNTT-TT
                    </button>
                </div>
                <div class="pt-2">
                    <button onclick="toggleMeetupModal(false)" class="w-full bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-xl text-sm">Đóng</button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL CHỈNH SỬA HỒ SƠ CÁ NHÂN (Yêu cầu bổ sung của UC01) -->
    <div id="profile-modal" class="fixed inset-0 bg-slate-900/60 z-[140] hidden flex items-center justify-center backdrop-blur-sm">
        <div class="bg-white rounded-2xl shadow-xl w-11/12 max-w-md p-6">
            <h3 class="text-lg font-bold text-slate-800 mb-4"><i class="fa-regular fa-user-gear text-sky-500 mr-2"></i>Cập nhật hồ sơ sinh viên</h3>
            <form id="form-profile" onsubmit="handleProfileUpdate(event)" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Họ và Tên</label>
                    <input type="text" id="profile-name" required class="w-full px-3 py-2 border border-slate-200 rounded-xl focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none text-sm">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Học viện / Trường trực thuộc</label>
                    <input type="text" id="profile-school" required placeholder="Trường Công Nghệ Thông Tin & Truyền Thông (ĐHCT)" class="w-full px-3 py-2 border border-slate-200 rounded-xl focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none text-sm">
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Số điện thoại liên hệ</label>
                    <input type="tel" id="profile-phone" required placeholder="09xxxxxxxx" class="w-full px-3 py-2 border border-slate-200 rounded-xl focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none text-sm">
                </div>
                <div class="flex gap-2 pt-2">
                    <button type="button" onclick="toggleProfileModal(false)" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium py-2 rounded-xl text-sm">Hủy</button>
                    <button type="submit" class="flex-1 bg-sky-500 hover:bg-sky-600 text-white font-medium py-2 rounded-xl text-sm">Lưu cập nhật</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL XEM LỊCH SỬ GIAO DỊCH ĐỐI SOÁT (Yêu cầu bổ sung của UC02) -->
    <div id="history-modal" class="fixed inset-0 bg-slate-900/60 z-[140] hidden flex items-center justify-center backdrop-blur-sm">
        <div class="bg-white rounded-3xl shadow-xl w-11/12 max-w-2xl p-6 max-h-[85vh] flex flex-col">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-lg font-bold text-slate-800"><i class="fa-solid fa-clock-rotate-left text-sky-500 mr-2"></i>Lịch sử giao dịch & đối soát</h3>
                <button onclick="toggleHistoryModal(false)" class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-xmark text-lg"></i></button>
            </div>
            
            <div class="flex-1 overflow-y-auto space-y-3 pr-1 no-scrollbar" id="history-list-container">
                <!-- JS sẽ nạp động các dòng lịch sử đối soát -->
            </div>
        </div>
    </div>

    <!-- -->
    <!-- VIEW 1: ĐĂNG NHẬP & ĐĂNG KÝ TÀI KHOẢN (Auth View) -->
    <section id="view-auth" class="view-section w-full h-full flex items-center justify-center p-4 bg-gradient-to-tr from-sky-400 via-sky-500 to-sky-600 relative overflow-hidden">
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-white/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md p-8 relative z-10 transition-all">
            <div class="text-center mb-6">
                <div class="w-16 h-16 bg-sky-100 text-sky-500 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-3 shadow-md shadow-sky-500/10">
                    <i class="fa-solid fa-graduation-cap"></i>
                </div>
                <h1 class="text-3xl font-extrabold text-sky-600 tracking-tight">Student Market</h1>
                <p class="text-slate-400 text-sm mt-1">Sàn giao dịch & thanh lý đồ cũ nội bộ Sinh Viên</p>
            </div>

            <!-- Tabs đăng nhập / đăng ký -->
            <div id="auth-tabs" class="flex bg-slate-100 p-1.5 rounded-xl mb-6">
                <button onclick="toggleAuthTab('login')" id="tab-login" class="flex-1 py-2 rounded-lg font-semibold text-sm transition-all bg-white text-sky-600 shadow-sm">Đăng Nhập</button>
                <button onclick="toggleAuthTab('register')" id="tab-register" class="flex-1 py-2 rounded-lg font-semibold text-sm transition-all text-slate-500 hover:text-slate-700">Đăng Ký</button>
            </div>

            <!-- FORM ĐĂNG NHẬP -->
            <form id="form-login" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Mã số Sinh viên / Email Trường</label>
                    <div class="relative">
                        <i class="fa-regular fa-envelope absolute left-4 top-3.5 text-slate-400"></i>
                        <input type="text" id="login-username" required placeholder="B20xxxxx / email@student.ctu.edu.vn" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none transition-all text-sm">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Mật khẩu</label>
                    <div class="relative">
                        <i class="fa-solid fa-lock absolute left-4 top-3.5 text-slate-400"></i>
                        <input type="password" id="login-password" required placeholder="••••••••" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none transition-all text-sm">
                    </div>
                </div>
                <div class="flex items-center justify-between text-xs">
                    <label class="flex items-center text-slate-500 cursor-pointer">
                        <input type="checkbox" id="login-remember" class="mr-1.5 rounded text-sky-500 focus:ring-sky-500 border-slate-300"> Ghi nhớ đăng nhập
                    </label>
                    <a href="#" onclick="showForgotForm()" class="text-sky-500 hover:text-sky-600 font-semibold">Quên mật khẩu?</a>
                </div>
                <button type="submit" id="btn-login-submit" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-xl shadow-lg shadow-sky-500/20 transition-all flex items-center justify-center gap-2">
                    Xác nhận đăng nhập <i class="fa-solid fa-arrow-right-to-bracket text-xs"></i>
                </button>
            </form>

            <!-- FORM ĐĂNG KÝ (UC01 + Kiểm tra mật khẩu mạnh có ký tự đặc biệt) -->
            <form id="form-register" class="space-y-4 hidden">
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Họ và Tên</label>
                    <div class="relative">
                        <i class="fa-regular fa-user absolute left-4 top-3.5 text-slate-400"></i>
                        <input type="text" id="reg-name" required placeholder="Nguyễn Văn A" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none transition-all text-sm">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Email sinh viên CTU</label>
                    <div class="relative">
                        <i class="fa-regular fa-envelope absolute left-4 top-3.5 text-slate-400"></i>
                        <input type="email" id="reg-email" required placeholder="xxxx@student.ctu.edu.vn" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none transition-all text-sm">
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Thiết lập Mật khẩu</label>
                    <div class="relative">
                        <i class="fa-solid fa-lock absolute left-4 top-3.5 text-slate-400"></i>
                        <input type="password" id="reg-pass" required placeholder="Yêu cầu ký tự đặc biệt và tối thiểu 6 ký tự..." oninput="checkPassStrength()" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none transition-all text-sm">
                    </div>
                    <!-- Thanh cảnh báo độ mạnh mật khẩu -->
                    <div class="mt-2 flex items-center gap-1">
                        <div id="strength-bar-1" class="h-1 flex-1 bg-slate-200 rounded transition-all"></div>
                        <div id="strength-bar-2" class="h-1 flex-1 bg-slate-200 rounded transition-all"></div>
                        <div id="strength-bar-3" class="h-1 flex-1 bg-slate-200 rounded transition-all"></div>
                    </div>
                    <span id="strength-label" class="text-[10px] text-slate-400 font-medium block mt-1">Độ mạnh mật khẩu</span>
                </div>
                <button type="submit" id="btn-register-submit" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 rounded-xl shadow-lg shadow-emerald-500/20 transition-all flex items-center justify-center gap-2">
                    Tạo tài khoản sinh viên <i class="fa-solid fa-user-plus text-xs"></i>
                </button>
            </form>

            <!-- -->
            <!-- FORM QUÊN MẬT KHẨU -->
            <form id="form-forgot" class="space-y-4 hidden">
                <!-- Bước 1: Nhập Email Trường -->
                <div id="forgot-step-1" class="space-y-4">
                    <p class="text-slate-500 text-xs leading-relaxed">Vui lòng nhập Email sinh viên CTU được cấp để khôi phục mật khẩu tài khoản Student Market.</p>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Email sinh viên CTU</label>
                        <div class="relative">
                            <i class="fa-regular fa-envelope absolute left-4 top-3.5 text-slate-400"></i>
                            <input type="email" id="forgot-email" placeholder="xxxx@student.ctu.edu.vn" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none transition-all text-sm">
                        </div>
                    </div>
                    <button type="button" onclick="sendResetOTP()" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-xl shadow-lg shadow-sky-500/20 transition-all flex items-center justify-center gap-2">
                        Gửi mã OTP xác thực <i class="fa-solid fa-paper-plane text-xs"></i>
                    </button>
                </div>

                <!-- Bước 2: Xác thực mã OTP -->
                <div id="forgot-step-2" class="space-y-4 hidden">
                    <div class="p-3 bg-sky-50 border border-sky-100 rounded-xl text-xs text-sky-700 flex gap-2">
                        <i class="fa-solid fa-circle-info text-sky-500 mt-0.5 shrink-0"></i>
                        <span>Mã xác nhận (OTP) đã được gửi đến email của bạn. Vui lòng kiểm tra hộp thư.</span>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Mã OTP (6 chữ số)</label>
                        <div class="relative">
                            <i class="fa-solid fa-key absolute left-4 top-3.5 text-slate-400"></i>
                            <input type="text" id="forgot-otp" maxlength="6" placeholder="******" class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none transition-all text-center tracking-widest font-extrabold text-lg">
                        </div>
                    </div>
                    <button type="button" onclick="verifyResetOTP()" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 rounded-xl shadow-lg shadow-sky-500/20 transition-all flex items-center justify-center gap-2">
                        Xác thực mã OTP <i class="fa-solid fa-shield-check text-xs"></i>
                    </button>
                </div>

                <!-- Bước 3: Đổi Mật Khẩu Mới -->
                <div id="forgot-step-3" class="space-y-4 hidden">
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Mật khẩu mới</label>
                        <div class="relative">
                            <i class="fa-solid fa-lock absolute left-4 top-3.5 text-slate-400"></i>
                            <input type="password" id="forgot-new-pass" placeholder="Tối thiểu 6 ký tự..." class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none transition-all text-sm">
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Xác nhận mật khẩu mới</label>
                        <div class="relative">
                            <i class="fa-solid fa-lock absolute left-4 top-3.5 text-slate-400"></i>
                            <input type="password" id="forgot-confirm-pass" placeholder="Nhập lại mật khẩu..." class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:bg-white focus:border-sky-500 focus:ring-2 focus:ring-sky-100 outline-none transition-all text-sm">
                        </div>
                    </div>
                    <button type="button" onclick="submitNewPassword()" class="w-full bg-emerald-500 hover:bg-emerald-600 text-white font-bold py-3 rounded-xl shadow-lg shadow-emerald-500/20 transition-all flex items-center justify-center gap-2">
                        Cập nhật mật khẩu mới <i class="fa-solid fa-circle-check text-xs"></i>
                    </button>
                </div>

                <!-- Nút quay lại login -->
                <div class="text-center pt-2">
                    <button type="button" onclick="showLoginForm()" class="text-xs text-slate-400 hover:text-sky-500 font-bold transition-colors inline-flex items-center gap-1.5">
                        <i class="fa-solid fa-arrow-left text-[10px]"></i> Quay lại Đăng Nhập
                    </button>
                </div>
            </form>

            <!-- Social Logins -->
            <div id="auth-social">
                <div class="relative my-6 text-center">
                    <span class="absolute inset-x-0 top-1/2 -translate-y-1/2 border-b border-slate-100"></span>
                    <span class="relative bg-white px-3 text-xs text-slate-400 font-semibold uppercase tracking-wider">Hoặc đăng nhập nhanh bằng</span>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <button onclick="socialLogin('Google')" class="flex items-center justify-center gap-2 py-2.5 border border-slate-200 hover:bg-slate-50 rounded-xl text-sm font-semibold text-slate-600 transition-colors">
                        <i class="fa-brands fa-google text-red-500"></i> Google
                    </button>
                    <button onclick="socialLogin('Facebook')" class="flex items-center justify-center gap-2 py-2.5 border border-slate-200 hover:bg-slate-50 rounded-xl text-sm font-semibold text-slate-600 transition-colors">
                        <i class="fa-brands fa-facebook text-blue-600"></i> Facebook
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- -->
    <!-- KHUNG CHƯƠNG TRÌNH GIAO DIỆN CHÍNH (Ẩn trước khi login) -->
    <div id="app-container" class="hidden h-full flex-col">
        
        <!-- HEADER CHUNG -->
        <header class="bg-white border-b border-sky-100 sticky top-0 z-40 shadow-sm">
            <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between gap-4">
                <!-- Logo & Trở về trang chủ -->
                <div class="flex items-center gap-2 cursor-pointer" onclick="switchView('home')">
                    <div class="w-10 h-10 bg-sky-500 text-white rounded-xl flex items-center justify-center text-xl shadow-md shadow-sky-500/20">
                        <i class="fa-solid fa-graduation-cap"></i>
                    </div>
                    <span class="font-extrabold text-xl text-sky-600 tracking-tight hidden sm:block">Student Market</span>
                </div>

